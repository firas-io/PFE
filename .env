PORT=5000
MONGO_URI=mongodb://127.0.0.1/habitflow
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi

ADMIN_EMAIL=admin@habitflow.com
ADMIN_PASSWORD=Admin123!

# Default Admin Profile (optional)
ADMIN_NOM=Admin
ADMIN_PRENOM=System

# LDAP (OpenLDAP via docker-compose)
LDAP_ENABLED=true
# Use ldap://openldap:389 when running backend inside docker-compose
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=ou=people,dc=habitflow,dc=local
LDAP_BIND_DN=cn=admin,dc=habitflow,dc=local
LDAP_BIND_PASSWORD=admin
LDAP_USER_FILTER=(mail={{username}})
